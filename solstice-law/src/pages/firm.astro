---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout title="About Us — Solstice Law">
  <Header />

  <main>
    <!-- 1. Hero Section -->
    <section class="relative pt-36 pb-24 flex items-center justify-center bg-brand-dark overflow-hidden">
      <!-- Abstract shapes / background -->
      <div class="absolute inset-0 z-0">
        <!-- Using a dark gradient + pseudo shape to mimic the abstract background -->
        <div class="absolute inset-0 bg-gradient-to-br from-brand-darker via-brand-dark to-[#4A443F]"></div>
        <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-white/[0.02] transform rotate-45 translate-x-1/3 -translate-y-1/2"></div>
      </div>

      <div class="max-w-[1200px] mx-auto px-6 w-full relative z-10 text-center">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-serif text-white leading-tight mb-4">
          Tentang <span class="italic font-light text-brand-primary">Firma</span>
        </h1>
        <div class="flex items-center justify-center gap-2 text-xs font-bold tracking-widest uppercase text-brand-beige">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span>/</span>
          <span class="text-white">Tentang Firma</span>
        </div>
      </div>
    </section>

    <!-- 2. About Section (Re-used from Home) -->
    <section class="py-24 bg-white relative">
      <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          
          <div class="space-y-8">
            <div class="flex items-center gap-4">
              <div class="w-2 h-2 bg-brand-primary"></div>
              <span class="text-xs uppercase tracking-widest font-bold text-slate-800">About the Firm</span>
            </div>
            
            <h2 class="text-5xl md:text-6xl font-serif text-brand-dark leading-tight">
              Kejelasan di Setiap, <br/><span class="italic font-light text-brand-primary">Keputusan</span>
            </h2>
            
            <p class="text-[15px] leading-relaxed text-slate-600 max-w-md">
              Solstice Law berdiri dari keyakinan bahwa persoalan hukum tidak seharusnya membuat klien kehilangan arah. Kami hadir untuk membantu individu, bisnis, dan organisasi memahami risiko, melihat pilihan yang tersedia, dan mengambil keputusan dengan dasar hukum yang kuat.
            </p>
            
            <p class="text-[15px] leading-relaxed text-slate-600 max-w-md">
              Kami memadukan ketelitian analitis dengan pemahaman komersial yang dalam untuk memastikan Anda selalu berada pada posisi yang lebih aman.
            </p>
            
            <div class="flex items-center gap-8 pt-4">
              <img src="/images/logo-only.png" alt="Solstice Law Icon" class="h-24 w-auto object-contain" />
              <Button href="/contact" variant="primary">Book a Call Today</Button>
            </div>
          </div>

          <div class="relative">
            <div class="bg-brand-beige/20 absolute -inset-4 transform translate-x-4 translate-y-4"></div>
            <img src="/images/tingey-injury-law-firm-justice-statue.webp" alt="Justice Statue" class="relative z-10 w-full h-[600px] object-cover" />
          </div>
          
        </div>
      </div>
    </section>

    <!-- 3. Why Choose Solstice Law -->
    <section class="relative py-24 bg-brand-dark overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img src="/images/practice_area.png" alt="Office Background" class="w-full h-full object-cover blur-sm opacity-20 mix-blend-overlay" />
        <div class="absolute inset-0 bg-brand-dark/95"></div>
      </div>

      <div class="max-w-[1200px] mx-auto px-6 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
          
          <!-- Text Content (Left) -->
          <div class="lg:col-span-5 space-y-8">
            <div class="flex items-center gap-4">
              <div class="w-2 h-2 bg-brand-primary"></div>
              <span class="text-xs uppercase tracking-widest font-bold text-brand-beige">Solstice Law Advantage</span>
            </div>
            <h2 class="text-4xl md:text-5xl font-serif text-white leading-tight">
              Why Choose <br/><span class="italic font-light text-brand-primary">Solstice Law</span>
            </h2>
            <p class="text-[15px] leading-relaxed text-brand-beige/80 max-w-md">
              Kami tidak hanya memberikan pandangan hukum, tetapi merumuskan strategi komprehensif yang dirancang khusus untuk mengamankan posisi Anda secara jangka panjang.
            </p>
            <div class="pt-4">
              <Button href="/contact" variant="primary">Consult With Us</Button>
            </div>
          </div>

          <!-- Cards (Right) -->
          <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-8">
            {[
              { 
                icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>',
                title: "Clarity & Discretion",
                desc: "Setiap rekomendasi dapat dipahami tanpa jargon rumit, kerahasiaan Anda adalah prioritas utama."
              },
              {
                icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>',
                title: "Strategic Edge",
                desc: "Solusi hukum yang selalu mempertimbangkan tujuan komersial secara proaktif dan berorientasi hasil."
              }
            ].map((card, index) => (
              <div class={`bg-white p-10 shadow-xl group border-t-4 border-brand-primary ${index === 1 ? 'sm:mt-12' : ''}`}>
                <div class="w-14 h-14 bg-brand-beige/50 rounded-full flex items-center justify-center text-brand-primary mb-8 group-hover:bg-brand-primary group-hover:text-white transition-colors duration-300">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={card.icon}></svg>
                </div>
                <h3 class="text-2xl font-serif text-brand-dark mb-4 group-hover:text-brand-primary transition-colors">{card.title}</h3>
                <p class="text-[14px] leading-relaxed text-slate-600">
                  {card.desc}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- 5. Latest News -->
    <section class="py-24 bg-brand-beige">
      <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
          
          <div class="relative">
            <img src="/images/hero_family.png" alt="Happy family" class="w-full h-[500px] object-cover rounded-sm shadow-md" />
          </div>

          <div>
            <div class="flex items-center justify-between mb-12">
              <div>
                <div class="flex items-center gap-4 mb-4">
                  <div class="w-2 h-2 bg-brand-primary"></div>
                  <span class="text-xs uppercase tracking-widest font-bold text-slate-800">Insights & Guidance</span>
                </div>
                <h2 class="text-4xl md:text-5xl font-serif text-brand-dark">Latest News</h2>
              </div>
              <Button href="#" variant="primary" class="hidden md:flex !px-6 !py-2.5">View All</Button>
            </div>

            <div class="space-y-8">
              {[
                { cat: 'ESTATE PLANNING', title: 'Avoid These Common & Expensive Mistakes: How To Leave A Lasting Legacy', img: '/images/indoor_family.png' },
                { cat: 'ESTATE PLANNING', title: 'Yours, Mine & Ours: Estate Planning For Modern Florida Families', img: '/images/news_family.png' }
              ].map(post => (
                <a href="#" class="flex gap-6 group">
                  <img src={post.img} alt={post.title} class="w-32 h-32 object-cover flex-shrink-0 border border-black/5" />
                  <div class="flex flex-col justify-center">
                    <span class="text-[10px] uppercase font-bold tracking-widest text-brand-primary mb-2">{post.cat}</span>
                    <h3 class="text-lg font-serif text-brand-dark group-hover:text-brand-primary transition-colors leading-snug mb-2">{post.title}</h3>
                    <p class="text-xs text-slate-600 line-clamp-2 leading-relaxed">
                      You love your children and want to ensure that they are always taken care of...
                    </p>
                  </div>
                </a>
              ))}
            </div>
            
            <Button href="#" variant="primary" class="md:hidden mt-10 w-full">View All</Button>
          </div>
          
        </div>
      </div>
    </section>

    <!-- 6. Secure Your Future Today (Form) -->
    <section class="relative py-24 pb-48">
      <div class="absolute inset-0 z-0">
        <img src="/images/hero_family.png" alt="Beach family" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-brand-darker/80"></div>
      </div>

      <div class="relative z-10 max-w-[800px] mx-auto px-6">
        <div class="text-center mb-12">
          <div class="flex items-center justify-center gap-4 mb-4">
            <div class="w-2 h-2 bg-brand-primary"></div>
            <span class="text-xs uppercase tracking-widest font-bold text-brand-beige">Schedule Your Consultation</span>
          </div>
          <h2 class="text-4xl md:text-5xl font-serif text-white mb-4">Secure Your Future Today</h2>
          <p class="text-brand-light/80 text-sm">Let's build a plan that protects what matters most.</p>
        </div>

        <form class="space-y-6" onsubmit="event.preventDefault();">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-[11px] font-bold text-white mb-2 uppercase tracking-wide">First Name</label>
              <input type="text" class="w-full px-4 py-3 bg-white text-brand-dark focus:outline-none focus:ring-2 focus:ring-brand-primary rounded-sm" />
            </div>
            <div>
              <label class="block text-[11px] font-bold text-white mb-2 uppercase tracking-wide">Last Name</label>
              <input type="text" class="w-full px-4 py-3 bg-white text-brand-dark focus:outline-none focus:ring-2 focus:ring-brand-primary rounded-sm" />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-[11px] font-bold text-white mb-2 uppercase tracking-wide">Phone Number</label>
              <input type="tel" class="w-full px-4 py-3 bg-white text-brand-dark focus:outline-none focus:ring-2 focus:ring-brand-primary rounded-sm" />
            </div>
            <div>
              <label class="block text-[11px] font-bold text-white mb-2 uppercase tracking-wide">Email Address</label>
              <input type="email" class="w-full px-4 py-3 bg-white text-brand-dark focus:outline-none focus:ring-2 focus:ring-brand-primary rounded-sm" />
            </div>
          </div>
          
          <div>
            <label class="block text-[11px] font-bold text-white mb-2 uppercase tracking-wide">How did you hear about us?</label>
            <select class="w-full px-4 py-3 bg-white text-brand-dark focus:outline-none focus:ring-2 focus:ring-brand-primary rounded-sm appearance-none">
              <option>How did you hear about us?</option>
              <option>Google Search</option>
              <option>Referral</option>
            </select>
          </div>

          <div>
            <label class="block text-[11px] font-bold text-white mb-2 uppercase tracking-wide">Message</label>
            <textarea rows="4" class="w-full px-4 py-3 bg-white text-brand-dark focus:outline-none focus:ring-2 focus:ring-brand-primary rounded-sm"></textarea>
          </div>

          <div class="flex items-center justify-between flex-wrap gap-4 pt-2">
            <label class="flex items-center gap-2 cursor-pointer text-white">
              <input type="checkbox" class="w-4 h-4 text-brand-primary rounded-sm border-white/20" required />
              <span class="text-[11px] font-light">I consent to the <a href="#" class="underline">privacy policy</a></span>
            </label>
            <Button type="submit" variant="primary" class="!px-10 !py-3">Submit</Button>
          </div>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
