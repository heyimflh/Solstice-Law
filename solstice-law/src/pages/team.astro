---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const teamMembers = [
  {
    name: "Adinda Oktavianti",
    degree: "S.H., M.H.",
    role: "Managing Partner",
    expertise: ["Corporate Advisory", "Commercial Disputes", "Regulatory Compliance"],
    bio: "Adinda memiliki pengalaman ekstensif dalam menangani transaksi komersial kompleks dan sengketa lintas yurisdiksi. Ia berfokus pada penyelesaian yang strategis dan berorientasi pada bisnis.",
    image: "/tim/Adinda%20Oktavianti.jpeg",
    linkedin: "https://linkedin.com",
  },
  {
    name: "Andri Setiawan",
    degree: "S.H., LL.M.",
    role: "Partner",
    expertise: ["Property Law", "Contract Drafting", "Estate Matters"],
    bio: "Dengan latar belakang hukum perusahaan yang kuat, Andri ahli dalam menyusun struktur perjanjian komersial dan memastikan setiap aspek legal terlindungi secara komprehensif.",
    image: "/tim/Andri%20Setiawan.jpeg",
    linkedin: "https://linkedin.com",
  },
  {
    name: "Dhea Anisa Putri",
    degree: "S.H.",
    role: "Senior Associate",
    expertise: ["Employment Law", "Intellectual Property", "Legal Risk Assessment"],
    bio: "Dhea sering mendampingi perusahaan teknologi dalam perlindungan aset intelektual serta penyelesaian sengketa ketenagakerjaan secara efisien.",
    image: "/tim/Dhea%20Anisa%20Putri.jpeg",
    linkedin: "https://linkedin.com",
  },
  {
    name: "Lina Nuraeni Rahmawati",
    degree: "S.H., M.Kn.",
    role: "Partner",
    expertise: ["Family & Estate", "Corporate Restructuring", "Civil Litigation"],
    bio: "Lina memiliki fokus utama pada hukum keluarga dan waris, serta sering mendampingi klien dalam negosiasi restrukturisasi perusahaan dengan pendekatan holistik.",
    image: "/tim/Lina%20Nuraeni%20Rahmawati.jpeg",
    linkedin: "https://linkedin.com",
  },
  {
    name: "Muhammad Syafiq Ramadhan",
    degree: "S.H.",
    role: "Senior Associate",
    expertise: ["Dispute Resolution", "Arbitration", "Criminal Defense"],
    bio: "Syafiq adalah litigator tangguh yang banyak menangani kasus litigasi perdata maupun pidana di berbagai tingkat pengadilan serta arbitrase nasional.",
    image: "/tim/Muhammad%20Syafiq%20Ramadhan.jpeg",
    linkedin: "https://linkedin.com",
  },
  {
    name: "Riva Esya Agustiyani",
    degree: "S.H.",
    role: "Associate",
    expertise: ["Foreign Investment", "M&A", "Tech & Privacy"],
    bio: "Riva berfokus pada penanaman modal asing dan transaksi M&A. Ia selalu memberikan opini hukum yang inovatif dan terukur untuk meminimalisasi risiko bisnis.",
    image: "/tim/Riva%20Esya%20Agustiyani.jpeg",
    linkedin: "https://linkedin.com",
  },
  {
    name: "Saharani Nurul Agni",
    degree: "S.H.",
    role: "Associate",
    expertise: ["Banking & Finance", "Insolvency", "Commercial Contracts"],
    bio: "Saharani secara reguler mendampingi klien di sektor perbankan dan multifinance dalam menstrukturisasi fasilitas pinjaman dan penanganan kepailitan.",
    image: "/tim/Saharani%20Nurul%20Agni.jpeg",
    linkedin: "https://linkedin.com",
  },
  {
    name: "Zulfa Hoirul Bariyah",
    degree: "S.H.",
    role: "Associate",
    expertise: ["Capital Market", "Tax Law", "General Corporate"],
    bio: "Zulfa memiliki pemahaman mendalam terkait regulasi pasar modal dan hukum pajak. Ia mendedikasikan dirinya untuk memberikan konsultasi harian bagi klien korporat.",
    image: "/tim/Zulfa%20Hoirul%20Bariyah.jpeg",
    linkedin: "https://linkedin.com",
  }
];
---

<BaseLayout title="Tim Profesional — Solstice Law">
  <Header />

  <main class="flex-grow">
    <!-- Page Hero -->
    <section class="relative pt-36 pb-24 flex items-center justify-center bg-brand-dark overflow-hidden">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-br from-brand-darker via-brand-dark to-[#4A443F]"></div>
      </div>

      <div class="max-w-[1200px] mx-auto px-6 w-full relative z-10 text-center">
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-serif text-white leading-tight mb-4">
          The <span class="italic font-light text-brand-primary">Attorneys</span>
        </h1>
        <div class="flex items-center justify-center gap-2 text-xs font-bold tracking-widest uppercase text-brand-beige">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span>/</span>
          <span class="text-white">Attorneys</span>
        </div>
      </div>
    </section>

    <!-- Team Grid -->
    <section class="py-24 bg-brand-beige">
      <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-12">
          {teamMembers.map(member => (
            <div class="group bg-white p-4 sm:p-6 shadow-md hover:shadow-xl transition-all duration-300">
              <div class="relative overflow-hidden mb-6 bg-brand-dark">
                <img src={member.image} alt={member.name} class="w-full aspect-[3/4] object-cover transition-transform duration-700 group-hover:scale-105 opacity-90 group-hover:opacity-100" />
                
                {member.linkedin && (
                  <a href={member.linkedin} target="_blank" rel="noopener noreferrer" class="absolute bottom-4 right-4 w-10 h-10 bg-brand-primary rounded-full flex items-center justify-center text-white opacity-0 transform translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 shadow-lg">
                    <span class="sr-only">LinkedIn</span>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" />
                    </svg>
                  </a>
                )}
              </div>
              
              <h2 class="text-xl sm:text-2xl font-serif text-brand-dark mb-1 group-hover:text-brand-primary transition-colors">{member.name}{member.degree && <span class="text-base sm:text-lg font-normal text-slate-500 ml-1">, {member.degree}</span>}</h2>
              <p class="text-brand-primary text-xs uppercase tracking-widest font-bold mb-4">{member.role}</p>
              <p class="text-slate-600 text-sm leading-relaxed mb-6">{member.bio}</p>
              
              <div class="border-t border-brand-beige pt-4">
                <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-3">Spesialisasi:</p>
                <div class="flex flex-wrap gap-2">
                  {member.expertise.map(exp => (
                    <span class="inline-block px-3 py-1 bg-brand-beige/50 text-[11px] font-medium text-slate-700">{exp}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
