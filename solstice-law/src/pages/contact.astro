---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';

const categories = [
  "Corporate & Commercial Advisory",
  "Contract Drafting & Review",
  "Dispute Resolution",
  "Employment & Industrial Relations",
  "Intellectual Property Protection",
  "Family & Estate Matters",
  "Regulatory Compliance",
  "Real Estate & Property",
  "Legal Risk Assessment",
  "Lainnya"
];
---

<BaseLayout title="Contact Us — Solstice Law">
  <Header />

  <main class="flex-grow">
    <!-- Page Hero -->
    <section class="relative pt-36 pb-24 flex items-center justify-center bg-brand-dark overflow-hidden">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-br from-brand-darker via-brand-dark to-[#4A443F]"></div>
      </div>

      <div class="max-w-[1200px] mx-auto px-6 w-full relative z-10 text-center">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-serif text-white leading-tight mb-4">
          Contact <span class="italic font-light text-brand-primary">Us</span>
        </h1>
        <div class="flex items-center justify-center gap-2 text-xs font-bold tracking-widest uppercase text-brand-beige">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span>/</span>
          <span class="text-white">Contact</span>
        </div>
      </div>
    </section>

    <!-- Info & Map -->
    <section class="py-24 bg-white">
      <div class="max-w-[1200px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        
        <div class="space-y-12">
          <div>
            <div class="flex items-center gap-4 mb-4">
              <div class="w-2 h-2 bg-brand-primary"></div>
              <span class="text-xs uppercase tracking-widest font-bold text-slate-800">Get In Touch</span>
            </div>
            <h2 class="text-4xl font-serif text-brand-dark mb-6">Informasi Kontak</h2>
            <p class="text-slate-600 leading-relaxed text-sm max-w-md">Tim kami siap membantu Anda dengan layanan hukum yang strategis dan rahasia. Silakan hubungi kami melalui informasi di bawah ini.</p>
          </div>

          <ul class="space-y-8">
            <li class="flex items-start gap-6">
              <div class="w-12 h-12 bg-brand-beige/50 flex items-center justify-center flex-shrink-0 text-brand-primary">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              </div>
              <div>
                <p class="font-bold text-brand-dark mb-1 text-sm uppercase tracking-wider">Alamat Kantor</p>
                <p class="text-slate-600 text-sm">Jl. AH. Nasution No.105, Cipadung Wetan<br/>Kec. Cibiru, Kota Bandung, Jawa Barat 40614</p>
              </div>
            </li>
            <li class="flex items-start gap-6">
              <div class="w-12 h-12 bg-brand-beige/50 flex items-center justify-center flex-shrink-0 text-brand-primary">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <div>
                <p class="font-bold text-brand-dark mb-1 text-sm uppercase tracking-wider">Email</p>
                <a href="mailto:contact@solsticelaw.id" class="text-brand-primary hover:text-brand-dark transition-colors text-sm">contact@solsticelaw.id</a>
              </div>
            </li>
            <li class="flex items-start gap-6">
              <div class="w-12 h-12 bg-brand-beige/50 flex items-center justify-center flex-shrink-0 text-brand-primary">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <div>
                <p class="font-bold text-brand-dark mb-1 text-sm uppercase tracking-wider">Telepon & WhatsApp</p>
                <p class="text-slate-600 text-sm mb-1">+62 856-0229-8305 (WhatsApp)</p>
              </div>
            </li>
          </ul>
        </div>

        <div class="h-[500px] w-full bg-slate-200 relative shadow-xl">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3960.660269468796!2d107.71518657504389!3d-6.931147793068728!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e68c302db3434f5%3A0xdf4aacdb8618199c!2sSunan%20Gunung%20Djati%20State%20Islamic%20University%20Bandung!5e0!3m2!1sen!2sid!4v1782792333674!5m2!1sen!2sid" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="strict-origin-when-cross-origin"
            title="Lokasi Kantor Solstice Law">
          </iframe>
          <div class="absolute inset-0 pointer-events-none border-[12px] border-brand-beige mix-blend-overlay"></div>
        </div>

      </div>
    </section>

    <!-- Secure Your Future Today (Form) -->
    <section class="relative py-24 pb-48">
      <div class="absolute inset-0 z-0">
        <img src="/images/hero_family.png" alt="Beach family" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-brand-darker/80"></div>
      </div>

      <div class="relative z-10 max-w-[800px] mx-auto px-6">
        <div class="text-center mb-12">
          <div class="flex items-center justify-center gap-4 mb-4">
            <div class="w-2 h-2 bg-brand-primary"></div>
            <span class="text-xs uppercase tracking-widest font-bold text-brand-beige">Schedule Your Consultation</span>
          </div>
          <h2 class="text-4xl md:text-5xl font-serif text-white mb-4">Secure Your Future Today</h2>
          <p class="text-brand-light/80 text-sm">Let's build a plan that protects what matters most.</p>
        </div>

        <form id="contactForm" class="space-y-6" onsubmit="event.preventDefault(); submitForm();">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-[11px] font-bold text-white mb-2 uppercase tracking-wide">First Name</label>
              <input type="text" id="name" required class="w-full px-4 py-3 bg-white text-brand-dark focus:outline-none focus:ring-2 focus:ring-brand-primary rounded-sm" />
            </div>
            <div>
              <label class="block text-[11px] font-bold text-white mb-2 uppercase tracking-wide">Last Name</label>
              <input type="text" class="w-full px-4 py-3 bg-white text-brand-dark focus:outline-none focus:ring-2 focus:ring-brand-primary rounded-sm" />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-[11px] font-bold text-white mb-2 uppercase tracking-wide">Phone Number</label>
              <input type="tel" class="w-full px-4 py-3 bg-white text-brand-dark focus:outline-none focus:ring-2 focus:ring-brand-primary rounded-sm" />
            </div>
            <div>
              <label class="block text-[11px] font-bold text-white mb-2 uppercase tracking-wide">Email Address</label>
              <input type="email" required class="w-full px-4 py-3 bg-white text-brand-dark focus:outline-none focus:ring-2 focus:ring-brand-primary rounded-sm" />
            </div>
          </div>
          
          <div>
            <label class="block text-[11px] font-bold text-white mb-2 uppercase tracking-wide">Kategori Layanan</label>
            <select class="w-full px-4 py-3 bg-white text-brand-dark focus:outline-none focus:ring-2 focus:ring-brand-primary rounded-sm appearance-none">
              <option value="" disabled selected>Pilih Kategori Layanan</option>
              {categories.map(cat => (
                <option value={cat}>{cat}</option>
              ))}
            </select>
          </div>

          <div>
            <label class="block text-[11px] font-bold text-white mb-2 uppercase tracking-wide">Message</label>
            <textarea id="message" required minlength="10" rows="4" class="w-full px-4 py-3 bg-white text-brand-dark focus:outline-none focus:ring-2 focus:ring-brand-primary rounded-sm"></textarea>
          </div>

          <!-- Alert Placeholder -->
          <div id="formAlert" class="hidden p-4 rounded-sm text-sm" role="alert"></div>

          <div class="flex items-center justify-between flex-wrap gap-4 pt-2">
            <label class="flex items-center gap-2 cursor-pointer text-white">
              <input type="checkbox" required class="w-4 h-4 text-brand-primary rounded-sm border-white/20" />
              <span class="text-[11px] font-light">I consent to the <a href="#" class="underline">privacy policy</a></span>
            </label>
            <Button type="submit" id="submitBtn" variant="primary" class="!px-10 !py-3">Submit</Button>
          </div>
        </form>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline>
    function submitForm() {
      const form = document.getElementById('contactForm');
      const submitBtn = document.getElementById('submitBtn');
      
      // Simulate API call
      submitBtn.disabled = true;
      submitBtn.innerHTML = 'Sending...';

      setTimeout(() => {
        form.reset();
        showAlert('Thank you. Your message has been received.', 'success');
        submitBtn.disabled = false;
        submitBtn.innerText = 'Submit';
      }, 1500);
    }

    function showAlert(message, type) {
      const alert = document.getElementById('formAlert');
      alert.textContent = message;
      alert.classList.remove('hidden', 'bg-red-100', 'text-red-800', 'bg-green-100', 'text-green-800');
      
      if (type === 'error') {
        alert.classList.add('bg-red-100', 'text-red-800');
      } else {
        alert.classList.add('bg-green-100', 'text-green-800');
      }
    }
  </script>
</BaseLayout>
