---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const pages = [
  { title: 'Home', url: '/' },
  { title: 'Tentang Firma', url: '/firm' },
  { title: 'Pendekatan Kami', url: '/approach' },
  { title: 'Practice Areas', url: '/services' },
  { title: 'The Attorneys', url: '/team' },
  { title: 'Insights & News', url: '/blog' },
  { title: 'Contact Us', url: '/contact' },
  { title: 'Disclaimer & Privacy Policy', url: '/disclaimer' }
];
---

<BaseLayout title="Sitemap — Solstice Law">
  <Header />

  <main class="flex-grow">
    <section class="relative pt-36 pb-24 flex items-center justify-center bg-brand-dark overflow-hidden">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-br from-brand-darker via-brand-dark to-[#4A443F]"></div>
      </div>

      <div class="max-w-[1200px] mx-auto px-6 w-full relative z-10 text-center">
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-serif text-white leading-tight mb-4">
          Site<span class="italic font-light text-brand-primary">map</span>
        </h1>
        <div class="flex items-center justify-center gap-2 text-xs font-bold tracking-widest uppercase text-brand-beige">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span>/</span>
          <span class="text-white">Sitemap</span>
        </div>
      </div>
    </section>

    <section class="py-24 bg-brand-light">
      <div class="max-w-4xl mx-auto px-6 bg-white p-8 md:p-16 shadow-sm border border-slate-100">
        <h2 class="text-2xl font-bold font-serif text-brand-dark mb-8 border-b border-slate-100 pb-4">Halaman Website</h2>
        
        <ul class="space-y-4">
          {pages.map(page => (
            <li class="flex items-center gap-4">
              <div class="w-1.5 h-1.5 rounded-full bg-brand-primary"></div>
              <a href={page.url} class="text-lg text-slate-700 hover:text-brand-primary transition-colors font-medium">
                {page.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
