---
import Button from '../ui/Button.astro';
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-dark text-brand-light/70 font-sans mt-auto">
  <!-- Newsletter Banner -->
  <div class="max-w-[1200px] mx-auto px-6 -mt-12 relative z-20">
    <div class="bg-[#ab9a89] rounded px-10 py-8 flex flex-col md:flex-row items-center justify-between gap-8 shadow-xl">
      <div class="flex flex-col md:flex-row items-center gap-6 text-white w-full md:w-auto">
        <h2 class="font-serif italic text-4xl text-white">Stay Updated</h2>
        <p class="text-sm font-medium leading-snug max-w-[250px] border-l border-white/30 pl-6 hidden md:block">
          Dapatkan insight hukum terbaru untuk bisnis dan persoalan pribadi Anda.
        </p>
      </div>
      
      <form class="flex w-full md:w-auto gap-3 items-center" onsubmit="event.preventDefault();">
        <input 
          type="email" 
          placeholder="Your Email" 
          class="bg-white/90 text-brand-dark px-4 py-3 min-w-[250px] text-sm focus:outline-none focus:ring-2 focus:ring-white"
          required
        />
        <Button type="submit" variant="primary" class="!px-6 !py-3 !rounded-none shadow-md">Subscribe</Button>
      </form>
    </div>
  </div>

  <div class="max-w-[1200px] mx-auto px-6 pt-24 pb-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
    
    <!-- Brand Summary -->
    <div class="space-y-6 lg:col-span-1">
      <a href="/" class="flex items-center group">
        <img src="/images/wordmark-only.png" alt="Solstice Law" class="h-10 md:h-12 w-auto object-contain group-hover:scale-105 transition-transform origin-left brightness-0 invert opacity-90" />
      </a>
      <p class="text-[13px] leading-relaxed max-w-xs mt-6">
        Firma hukum modern yang membantu klien melewati titik penting dalam keputusan hukum dan bisnis dengan pendampingan yang strategis, tenang, dan terpercaya.
      </p>
    </div>

    <!-- Visit Us -->
    <div>
      <h3 class="text-brand-primary text-xs uppercase tracking-widest font-bold mb-6">Visit Us</h3>
      <ul class="space-y-2 text-[13px]">
        <li>Solstice Law</li>
        <li>Jl. AH. Nasution No.105</li>
        <li>Kota Bandung, ID 40614</li>
        <li><a href="#" class="text-brand-primary hover:underline mt-2 inline-block">Map & Directions</a></li>
      </ul>
    </div>

    <!-- Reach Us -->
    <div>
      <h3 class="text-brand-primary text-xs uppercase tracking-widest font-bold mb-6">Reach Us</h3>
      <ul class="space-y-2 text-[13px]">
        <li>Phone / WA: +62 856-0229-8305</li>
        <li>Email: contact@solsticelaw.id</li>
        <li><a href="/contact" class="text-brand-primary hover:underline mt-2 inline-block">Email Us</a></li>
      </ul>
    </div>

    <!-- Follow Us -->
    <div>
      <h3 class="text-brand-primary text-xs uppercase tracking-widest font-bold mb-6">Follow Us</h3>
      <div class="flex gap-4">
        <!-- Facebook Icon -->
        <a href="#" class="text-white hover:text-brand-primary transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
        </a>
        <!-- LinkedIn Icon -->
        <a href="#" class="text-white hover:text-brand-primary transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        </a>
        <!-- Instagram Icon -->
        <a href="#" class="text-white hover:text-brand-primary transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
      </div>
    </div>
    
  </div>

  <div class="max-w-[1200px] mx-auto px-6 border-t border-white/5 py-6 flex flex-col md:flex-row items-center gap-4 text-[11px] text-brand-light/50 tracking-wider">
    <p>&copy; {currentYear} Solstice Law | <a href="#" class="hover:text-brand-light transition-colors">Sitemap</a> | <a href="#" class="hover:text-brand-light transition-colors">Disclaimer</a> | <a href="#" class="hover:text-brand-light transition-colors">Privacy Policy</a></p>
  </div>
</footer>
